{
  "name": "taskgo-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "npm start --prefix frontend",
    "android": "npm run android --prefix frontend",
    "ios": "npm run ios --prefix frontend",
    "web": "npm run web --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "backend": "npm run dev --prefix backend",
    "backend:start": "npm start --prefix backend",
    "test": "npm test --prefix tests",
    "test:integration": "npm run test:integration --prefix tests",
    "test:frontend": "npm run test:frontend --prefix tests",
    "test:performance": "npm run test:performance:load --prefix tests && npm run test:performance:socket --prefix tests",
    "test:report": "npm run report:asr --prefix tests"
  },
  "dependencies": {
    "react-native-webview": "^13.16.1"
  }
}
