{
  "name": "taskgo-backend",
  "version": "1.0.0",
  "description": "TaskGo Home Service Booking Platform — Modular Monolith API",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch --runInBand",
    "mongo:smoke": "node scripts/mongo-smoke.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "reset-db": "node scripts/reset-db.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop taskgo-api"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@payos/node": "^2.0.5",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.24.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.1.0"
  },
  "private": true
}
