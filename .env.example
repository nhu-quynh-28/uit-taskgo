PORT=4000
NODE_ENV=development

# Required — no default. Use a long random string (min 32 chars in production).
JWT_SECRET=local-dev-only-change-me-min-32-chars!!
JWT_EXPIRES_IN=7d

# Data layer: inMemory | mongo
REPOSITORY_DRIVER=inMemory

# CORS — use explicit origins in production (wildcard "*" is rejected when NODE_ENV=production)
# Comma-separated (brackets optional): admin Vite ports + Expo web
CORS_ORIGIN=[http://localhost:5173,http://localhost:5174,http://localhost:8081]

# --- MongoDB (required when REPOSITORY_DRIVER=mongo) ---
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/taskgo?retryWrites=true&w=majority&appName=TaskGo-API
MONGODB_URI=
MONGODB_CONNECT_ON_STARTUP=true
MONGODB_MAX_RETRY_ATTEMPTS=5
MONGODB_RETRY_DELAY_MS=2000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_APP_NAME=TaskGo-API

# DB tooling (requires MONGODB_URI): npm run migrate | seed | reset-db

# payOS Merchant API (https://payos.vn/docs/sdks/back-end/node/)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# Deep links or HTTPS URLs shown after checkout in WebView
PAYOS_RETURN_URL=taskgo://payment/return
PAYOS_CANCEL_URL=taskgo://payment/cancel

PAYOS_MOCK_TIMEOUT_MS=5000
PAYOS_MOCK_FAIL_RATE=0.1
PAYOS_MOCK_FORCE_TIMEOUT=false
PAYOS_MOCK_FORCE_FAIL=false

IDEMPOTENCY_TTL_MS=86400000
NEARBY_TASKER_RADIUS_KM=20
