{
  "name": "taskgo-asr-tests",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "TaskGo ASR quality tests — integration, performance, and frontend usability",
  "scripts": {
    "test": "npm run test:integration && npm run test:frontend && node scripts/generate-asr-report.cjs",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.config.js --runInBand",
    "test:frontend": "NODE_OPTIONS=--experimental-vm-modules npx jest --config jest.frontend.config.js --runInBand",
    "test:performance:load": "node performance/load-test.js",
    "test:performance:socket": "node performance/socket-latency.js",
    "report:asr": "node scripts/generate-asr-report.cjs"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-test-renderer": "19.1.0",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.1.0",
    "typescript": "~5.9.2"
  }
}
